{
  "uid": "ollama",
  "title": "Ollama",
  "tags": ["ollama", "ai"],
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "60s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "ollama_up", "legendFormat": "ollama", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "DOWN", "color": "red" },
              "1": { "text": "UP", "color": "green" }
            }}
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Version",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "ollama_version_info", "legendFormat": "{{version}}", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Models",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "ollama_models_total", "legendFormat": "models", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Model Storage",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(ollama_model_size_bytes)", "legendFormat": "total", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 7,
      "title": "Loaded Models",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "ollama_ps_loaded_models_total", "legendFormat": "loaded", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "text", "value": null },
            { "color": "green", "value": 1 }
          ]}
        }
      }
    },
    {
      "id": 8,
      "title": "VRAM In Use",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(ollama_ps_model_size_vram_bytes)", "legendFormat": "vram", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 5,
      "title": "Model Sizes",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sort_desc(ollama_model_size_bytes)",
          "legendFormat": "{{model_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "xTickLabelRotation": -30,
        "xTickLabelMaxLength": 25,
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "fillOpacity": 80,
        "tooltipDisplayMode": "single",
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 1, "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 6,
      "title": "Model Inventory",
      "type": "table",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 12 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ollama_model_info",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "ollama_model_size_bytes",
          "legendFormat": "",
          "refId": "B",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "model_name",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value #A": true,
              "Value #B": false,
              "__name__": true,
              "instance": true,
              "job": true,
              "parent_model": true
            },
            "renameByName": {
              "model_name": "Model",
              "family": "Family",
              "format": "Format",
              "parameter_size": "Parameters",
              "quantization_level": "Quantization",
              "Value #B": "Size"
            },
            "indexByName": {
              "model_name": 0,
              "family": 1,
              "parameter_size": 2,
              "quantization_level": 3,
              "format": 4,
              "Value #B": 5
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Size" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Model" },
            "properties": [{ "id": "custom.width", "value": 220 }]
          },
          {
            "matcher": { "id": "byName", "options": "Parameters" },
            "properties": [{ "id": "custom.width", "value": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "Quantization" },
            "properties": [{ "id": "custom.width", "value": 120 }]
          }
        ]
      }
    }
    ,
    {
      "id": 9,
      "title": "Currently Loaded in Memory",
      "type": "row",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Loaded Models",
      "type": "table",
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ollama_ps_model_info",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "ollama_ps_model_size_vram_bytes",
          "legendFormat": "",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "ollama_ps_model_size_bytes",
          "legendFormat": "",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "ollama_ps_model_context_length",
          "legendFormat": "",
          "refId": "D",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "model", "mode": "outer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value #A": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "model": "Model",
              "family": "Family",
              "parameter_size": "Parameters",
              "quantization_level": "Quantization",
              "Value #B": "VRAM",
              "Value #C": "Total Size",
              "Value #D": "Context Length"
            },
            "indexByName": {
              "model": 0,
              "family": 1,
              "parameter_size": 2,
              "quantization_level": 3,
              "Value #D": 4,
              "Value #B": 5,
              "Value #C": 6
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "VRAM" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.width", "value": 130 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Total Size" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.width", "value": 130 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Context Length" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Model" },
            "properties": [{ "id": "custom.width", "value": 220 }]
          },
          {
            "matcher": { "id": "byName", "options": "Parameters" },
            "properties": [{ "id": "custom.width", "value": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "Quantization" },
            "properties": [{ "id": "custom.width", "value": 120 }]
          }
        ]
      }
    },
    {
      "id": 11,
      "title": "VRAM Usage — Loaded Models",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 35, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ollama_ps_model_size_vram_bytes",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      }
    }
  ]
}
