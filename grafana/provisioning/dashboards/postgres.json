{
  "uid": "postgres",
  "title": "PostgreSQL",
  "tags": ["postgres", "database"],
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "60s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datname",
        "label": "Database",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(pg_stat_database_numbackends, datname)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "pg_up", "legendFormat": "postgres", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "DOWN", "color": "red" },
              "1": { "text": "UP", "color": "green" }
            }}
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(pg_stat_database_numbackends)", "legendFormat": "connections", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "orange", "value": 50 }, { "color": "red", "value": 90 }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Transaction Rate",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(pg_stat_database_xact_commit[5m])) + sum(rate(pg_stat_database_xact_rollback[5m]))", "legendFormat": "tx/s", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Total DB Size",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(pg_database_size_bytes)", "legendFormat": "total", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 5,
      "title": "Cache Hit Ratio",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(pg_stat_database_blks_hit) / (sum(pg_stat_database_blks_hit) + sum(pg_stat_database_blks_read) + 1)",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.9 }, { "color": "green", "value": 0.99 }] }
        }
      }
    },
    {
      "id": 6,
      "title": "Active Connections by Database",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=~\"$datname\"}",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 7,
      "title": "Transaction Rate by Database",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=~\"$datname\"}[5m])",
          "legendFormat": "commit {{datname}}",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=~\"$datname\"}[5m])",
          "legendFormat": "rollback {{datname}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 8,
      "title": "Cache Hit Ratio by Database",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname=~\"$datname\"} / (pg_stat_database_blks_hit{datname=~\"$datname\"} + pg_stat_database_blks_read{datname=~\"$datname\"} + 1)",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 9,
      "title": "Tuple Operations by Database",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_inserted{datname=~\"$datname\"}[5m])",
          "legendFormat": "insert {{datname}}",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{datname=~\"$datname\"}[5m])",
          "legendFormat": "update {{datname}}",
          "refId": "B"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{datname=~\"$datname\"}[5m])",
          "legendFormat": "delete {{datname}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 10,
      "title": "Database Sizes",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sort_desc(pg_database_size_bytes)",
          "legendFormat": "{{datname}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "orange", "value": 1073741824 }, { "color": "red", "value": 10737418240 }] }
        }
      }
    }
  ]
}
