{
  "title": "Frigate NVR",
  "uid": "frigate-nvr",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["frigate", "nvr", "cameras"],
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Data Source",
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Service Status",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Uptime",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "frigate_service_uptime_seconds",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Version",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "frigate_service_info",
          "instant": true,
          "legendFormat": "{{version}}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "blue" }]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Detection FPS",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "frigate_detection_total_fps",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Inference Speed",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "frigate_detector_inference_speed_seconds * 1000",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 30, "color": "yellow" },
              { "value": 60, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "GPU Utilisation",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "frigate_gpu_usage_percent",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "GPU Memory",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "frigate_gpu_mem_usage_percent",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Storage",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "Recordings Disk",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 5, "w": 6, "h": 7 },
      "targets": [
        {
          "expr": "frigate_storage_used_bytes{storage=\"/media/frigate/recordings\"} / frigate_storage_total_bytes{storage=\"/media/frigate/recordings\"} * 100",
          "instant": true,
          "legendFormat": "Recordings"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "gauge",
      "title": "Clips Disk",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 6, "y": 5, "w": 6, "h": 7 },
      "targets": [
        {
          "expr": "frigate_storage_used_bytes{storage=\"/media/frigate/clips\"} / frigate_storage_total_bytes{storage=\"/media/frigate/clips\"} * 100",
          "instant": true,
          "legendFormat": "Clips"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "type": "gauge",
      "title": "RAM Cache (/tmp/cache)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 5, "w": 6, "h": 7 },
      "targets": [
        {
          "expr": "frigate_storage_used_bytes{storage=\"/tmp/cache\"} / frigate_storage_total_bytes{storage=\"/tmp/cache\"} * 100",
          "instant": true,
          "legendFormat": "Cache"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "type": "gauge",
      "title": "Shared Memory (/dev/shm)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 18, "y": 5, "w": 6, "h": 7 },
      "targets": [
        {
          "expr": "frigate_storage_used_bytes{storage=\"/dev/shm\"} / frigate_storage_total_bytes{storage=\"/dev/shm\"} * 100",
          "instant": true,
          "legendFormat": "/dev/shm"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Recordings Used",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 3 },
      "targets": [
        {
          "expr": "frigate_storage_used_bytes{storage=\"/media/frigate/recordings\"}",
          "instant": true,
          "legendFormat": "Used"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "text" }]
          }
        }
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Recordings Free",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 6, "y": 12, "w": 6, "h": 3 },
      "targets": [
        {
          "expr": "frigate_storage_free_bytes{storage=\"/media/frigate/recordings\"}",
          "instant": true,
          "legendFormat": "Free"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "text" }]
          }
        }
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Clips Used",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 3 },
      "targets": [
        {
          "expr": "frigate_storage_used_bytes{storage=\"/media/frigate/clips\"}",
          "instant": true,
          "legendFormat": "Used"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "text" }]
          }
        }
      }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Clips Free",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 3 },
      "targets": [
        {
          "expr": "frigate_storage_free_bytes{storage=\"/media/frigate/clips\"}",
          "instant": true,
          "legendFormat": "Free"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "text" }]
          }
        }
      }
    },
    {
      "id": 17,
      "type": "row",
      "title": "Camera Streams",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Camera FPS",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "frigate_camera_fps{camera_name=~\".+\"}",
          "legendFormat": "{{camera_name}} — camera",
          "refId": "A"
        },
        {
          "expr": "frigate_process_fps{camera_name=~\".+\"}",
          "legendFormat": "{{camera_name}} — process",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Detection FPS",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "frigate_detection_fps{camera_name=~\".+\"}",
          "legendFormat": "{{camera_name}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Skipped FPS",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "frigate_skipped_fps{camera_name=~\".+\"}",
          "legendFormat": "{{camera_name}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 21,
      "type": "row",
      "title": "Detection Events",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 22,
      "type": "table",
      "title": "Event Counts by Camera & Label (since restart)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 33, "w": 12, "h": 10 },
      "targets": [
        {
          "expr": "sort_desc(frigate_camera_events_total)",
          "instant": true,
          "legendFormat": "",
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "indexByName": { "camera": 0, "label": 1, "Value": 2 },
            "renameByName": { "camera": "Camera", "label": "Label", "Value": "Events" }
          }
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "Events", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Events" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "value": null, "color": "green" },
                    { "value": 50, "color": "yellow" },
                    { "value": 200, "color": "orange" }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Event Rate (5m window)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 33, "w": 12, "h": 10 },
      "targets": [
        {
          "expr": "sum by (camera, label) (increase(frigate_camera_events_total[5m]))",
          "legendFormat": "{{camera}} — {{label}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "drawStyle": "bars",
            "barAlignment": 0
          }
        }
      }
    },
    {
      "id": 24,
      "type": "row",
      "title": "Process Health",
      "gridPos": { "x": 0, "y": 43, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "FFmpeg CPU % by Camera",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 44, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (name) (frigate_cpu_usage_percent{process=\"ffmpeg\", type=\"Camera\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 26,
      "type": "timeseries",
      "title": "Detect CPU % by Camera",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 44, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (name) (frigate_cpu_usage_percent{process=\"detect\", type=\"Camera\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 27,
      "type": "timeseries",
      "title": "Frigate Total Memory Usage",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 52, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "frigate_mem_usage_percent{pid=\"frigate.full_system\"}",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "sum by (name) (frigate_mem_usage_percent{type=\"Camera\", process=\"ffmpeg\"})",
          "legendFormat": "{{name}} ffmpeg",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 28,
      "type": "timeseries",
      "title": "Detector Inference Speed",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 52, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "frigate_detector_inference_speed_seconds * 1000",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 1, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 30, "color": "yellow" },
              { "value": 60, "color": "red" }
            ]
          }
        }
      }
    }
  ]
}
