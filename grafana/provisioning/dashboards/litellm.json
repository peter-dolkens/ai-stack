{
  "uid": "litellm",
  "title": "LiteLLM",
  "tags": ["litellm", "ai"],
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "up{job=\"litellm\"}", "legendFormat": "litellm", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "DOWN", "color": "red" },
              "1": { "text": "UP", "color": "green" }
            }}
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(litellm_requests_metric_total[5m]))", "legendFormat": "req/s", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Input Tokens / min",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(litellm_input_tokens_metric_total[5m])) * 60", "legendFormat": "tokens/min", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Output Tokens / min",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(litellm_output_tokens_metric_total[5m])) * 60", "legendFormat": "tokens/min", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Spend (all time)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(litellm_spend_metric_total)", "legendFormat": "USD", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }] }
        }
      }
    },
    {
      "id": 6,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(litellm_requests_metric_total{status!=\"success\"}[5m])) or vector(0)", "legendFormat": "err/s", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] }
        }
      }
    },
    {
      "id": 7,
      "title": "Request Rate by Model",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (model) (rate(litellm_requests_metric_total[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 8,
      "title": "Input Tokens / min by Model",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (model) (rate(litellm_input_tokens_metric_total[5m])) * 60",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 9,
      "title": "Output Tokens / min by Model",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (model) (rate(litellm_output_tokens_metric_total[5m])) * 60",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 10,
      "title": "P50 / P95 / P99 Latency",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, model) (rate(litellm_llm_api_latency_metric_bucket[$__rate_interval])))",
          "legendFormat": "p50 {{model}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(litellm_llm_api_latency_metric_bucket[$__rate_interval])))",
          "legendFormat": "p95 {{model}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, model) (rate(litellm_llm_api_latency_metric_bucket[$__rate_interval])))",
          "legendFormat": "p99 {{model}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 12,
      "title": "Total Input Tokens",
      "type": "stat",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(last_over_time(litellm_input_tokens_metric_total[$__range])) - (sum(last_over_time(litellm_input_tokens_metric_total[$__range] offset $__range)) or vector(0))", "legendFormat": "input tokens", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 13,
      "title": "Total Output Tokens",
      "type": "stat",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(last_over_time(litellm_output_tokens_metric_total[$__range])) - (sum(last_over_time(litellm_output_tokens_metric_total[$__range] offset $__range)) or vector(0))", "legendFormat": "output tokens", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 14,
      "title": "Total Tokens",
      "type": "stat",
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(last_over_time(litellm_total_tokens_metric_total[$__range])) - (sum(last_over_time(litellm_total_tokens_metric_total[$__range] offset $__range)) or vector(0))",
          "legendFormat": "total tokens",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        }
      }
    },
    {
      "id": 15,
      "title": "Token Consumption by Model",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (model) (rate(litellm_output_tokens_metric_total[$__rate_interval]) * $__interval_ms / 1000)",
          "legendFormat": "{{model}} (output)",
          "refId": "A"
        },
        {
          "expr": "sum by (model) (rate(litellm_input_tokens_metric_total[$__rate_interval]) * $__interval_ms / 1000)",
          "legendFormat": "{{model}} (input)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "lineWidth": 0, "fillOpacity": 80, "drawStyle": "bars", "stacking": { "mode": "normal", "group": "output" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "custom.transform", "value": "negative-Y" },
              { "id": "custom.stacking", "value": { "mode": "normal", "group": "input" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 11,
      "title": "Spend Rate by Model (USD/hr)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (model) (rate(litellm_spend_metric_total[5m])) * 3600",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean"] },
        "tooltip": { "mode": "multi" }
      }
    }
  ]
}
