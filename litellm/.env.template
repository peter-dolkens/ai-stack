# LiteLLM master key — used to authenticate requests from OpenWebUI and direct API access.
# Must start with "sk-". Also set this value as OPENAI_API_KEY in open-webui/.env.
LITELLM_MASTER_KEY=

# Connection string for the shared postgres instance — auto-derived from postgres/.env.
DATABASE_URL=

# OpenAI API key (leave empty to disable OpenAI models)
OPENAI_API_KEY=

# Anthropic API key (leave empty to disable Anthropic models)
ANTHROPIC_API_KEY=

# Google Gemini API key (leave empty to disable Gemini models)
GEMINI_API_KEY=

# Microsoft Foundry API key (leave empty to disable Foundry models)
FOUNDRY_API_KEY=