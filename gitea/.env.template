# Postgres password — auto-derived from postgres/.env.
GITEA__database__PASSWD=

# Google OAuth client ID for Gitea authentication.
# From Google Cloud Console → APIs & Services → Credentials.
# Authorized redirect URIs (add both):
#   https://git.dolkens.net/user/oauth2/Google/callback
#   https://git.dolkens.au/user/oauth2/Google/callback
GITEA_OAUTH_CLIENT_ID=

# Google OAuth client secret.
GITEA_OAUTH_CLIENT_SECRET=
