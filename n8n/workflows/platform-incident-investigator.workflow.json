      "parameters": {
        "jsCode": "const item = $input.item.json;\nconst staticData = $getWorkflowStaticData('global');\n\n// Clean up entries older than 7 days\nconst cutoff = (Date.now() / 1000) - (7 * 24 * 60 * 60);\nif (!staticData.processed) staticData.processed = {};\nfor (const ts of Object.keys(staticData.processed)) {\n  if (parseFloat(ts) < cutoff) delete staticData.processed[ts];\n}\nfor (const ts of Object.keys(staticData)) {\n  if (ts !== 'processed' && parseFloat(ts) < cutoff) delete staticData[ts];\n}\n\n// Drop everything except plain messages and message_changed\nif (item.subtype && item.subtype !== 'message_changed') {\n  return [];\n}\n\n// Unwrap message_changed — real content is in item.message\nconst isMessageChanged = item.subtype === 'message_changed';\nlet msg = item;\nif (isMessageChanged && item.message) {\n  msg = { ...item.message, channel: item.channel, event_ts: item.event_ts };\n  // Drop deleted/hidden messages (tombstone, no text, or hidden flag)\n  if (!msg.text || msg.hidden || msg.subtype === 'tombstone') return [];\n}\n\nreturn [{ json: { ...msg, isMessageChanged } }];"
      },
