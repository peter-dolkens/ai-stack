    {
      "parameters": {
        "jsCode": "function extractText(node) {\n  if (!node) return '';\n  if (node.type === 'text') return node.text || '';\n  if (node.type === 'hardBreak') return '\\n';\n  if (node.type === 'mention') return node.attrs?.text || '';\n  if (node.content) {\n    const inner = node.content.map(extractText).join('');\n    if (node.type === 'paragraph') return inner + '\\n';\n    if (node.type === 'heading') return '*' + inner.trim() + '*\\n';\n    if (node.type === 'listItem') return '\\u2022 ' + inner.trimEnd() + '\\n';\n    if (node.type === 'codeBlock') return '`' + inner + '`\\n';\n    if (node.type === 'blockquote') return '> ' + inner;\n    return inner;\n  }\n  return '';\n}\n\nconst fields = $input.item.json.fields || {};\nconst rawDesc = fields.description;\n\nlet description = '';\nif (typeof rawDesc === 'string') {\n  description = rawDesc.trim();\n} else if (rawDesc?.content) {\n  description = extractText(rawDesc).trim();\n}\n\nif (description.length > 600) {\n  description = description.slice(0, 597) + '...';\n}\n\nreturn [{ json: { ...$input.item.json, formattedDescription: description } }];"
      },
