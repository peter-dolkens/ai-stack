        "jsCode": "const outputItems = $input.first().json.output;\nconst message = outputItems.find(item => item.content && item.content.length > 0);\nconst texts = message.content.map(item => {\n  let text = item.text;\n  try {\n    const parsed = JSON.parse(text);\n    const firstString = Object.values(parsed).find(v => typeof v === 'string');\n    if (firstString) text = firstString;\n  } catch (e) {\n    const match = text.match(/\"\\w+\"\\s*:\\s*\"([\\s\\S]*)/);\n    if (match) text = match[1].replace(/\"\\s*\\}?\\s*$/, '').replace(/\\\\n/g, '\\n');\n  }\n  return text;\n});\nreturn [{ json: { summary: texts.join('\\n') } }];"
