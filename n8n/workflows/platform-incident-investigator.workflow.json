      "parameters": {
        "jsCode": "const originalText = $('Build Channel Name').first().json.text || '';\nconst channel = $('Build Channel Name').first().json.channel;\nconst ts = $('Build Channel Name').first().json.ts;\nconst privateChannelId = $('Resolved Channel').first().json.channelId;\nconst input = $input.item.json;\n\n// Build Slack thread permalink\nconst tsPerma = 'p' + String(ts).replace('.', '');\nconst threadLink = `https://app.slack.com/archives/${channel}/${tsPerma}`;\n\nlet context = `Slack Incident Report:\\n${originalText}`;\n\nif (input.fields) {\n  const jiraInfo = $('Extract Jira Info').first().json;\n  const summary = input.fields.summary || '';\n  const status = input.fields.status?.name || '';\n  const priority = input.fields.priority?.name || 'None';\n  const issueType = input.fields.issuetype?.name || '';\n  const description = input.formattedDescription || '';\n\n  context += `\\n\\nJira Ticket: ${jiraInfo.jiraKey}\\nSummary: ${summary}\\nStatus: ${status} | Priority: ${priority} | Type: ${issueType}`;\n  if (description) context += `\\n\\nDescription:\\n${description}`;\n}\n\nreturn [{ json: { context, privateChannelId, threadLink } }];"
