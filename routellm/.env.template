# LiteLLM OpenAI-compatible backend URL
OPENAI_BASE_URL=http://litellm:4000

# LiteLLM master key — RouteLLM uses this to authenticate with LiteLLM.
# Must match LITELLM_MASTER_KEY from litellm/.env.
OPENAI_API_KEY=

# Strong model — used for complex/hard queries. Must be a model name from litellm/config.template.yaml.
ROUTELLM_STRONG_MODEL=openai/gpt-oss:120b (cs)

# Weak model — used for simple/easy queries. Should be a fast local model.
ROUTELLM_WEAK_MODEL=openai/gpt-oss:20b
